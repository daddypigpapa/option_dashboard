# Copy this file to ".env" and fill in your keys. Never commit the real .env.

# --- Required for macro data (free key: https://fred.stlouisfed.org/docs/api/api_key.html) ---
FRED_API_KEY=

# --- Korean corporate disclosures (free key: https://opendart.fss.or.kr/) ---
DART_API_KEY=

# --- 한국투자증권 OpenAPI (https://apiportal.koreainvestment.com) — KR market refresh ---
KIS_APP_KEY=
KIS_APP_SECRET=

# --- AI integration ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Optional paid providers for premium data (left blank -> those features are skipped) ---
# Institutional options flow (long/neutral/short). e.g. Unusual Whales, CBOE LiveVol, Polygon.
OPTIONS_FLOW_API_KEY=
OPTIONS_FLOW_PROVIDER=unusualwhales
# ETF fund flows (top inflow / outflow). e.g. ETF.com, FactSet, State Street.
ETF_FLOW_API_KEY=
ETF_FLOW_PROVIDER=

# --- Tuning ---
# Comma-separated. Leave blank to auto-fetch the live S&P 500 constituents.
UNIVERSE_OVERRIDE=
# Max tickers to process (useful for quick test runs). Blank = all.
MAX_TICKERS=
